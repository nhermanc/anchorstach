{
	"name": "phoenix-software-typescript",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev:clean": "node -e \"['.next','.next-dev'].forEach(function(d){ try { require('fs').rmSync(d, { recursive: true, force: true }); } catch (_) {} });\"",
		"dev:fresh": "npm run dev:clean && node scripts/run-dev.cjs",
		"dev": "node scripts/run-dev.cjs",
		"build": "node --openssl-legacy-provider ./node_modules/next/dist/bin/next build",
		"build:deploy": "node scripts/generate-public-seo.mjs && node --openssl-legacy-provider ./node_modules/next/dist/bin/next build && node --openssl-legacy-provider ./node_modules/next/dist/bin/next export -o deploy",
		"build:static": "npm run build:deploy",
		"analyze": "node scripts/run-analyze-build.cjs",
		"start": "node --openssl-legacy-provider ./node_modules/next/dist/bin/next start",
		"lint": "next lint",
		"fetch-upwork": "node scripts/fetch-upwork-testimonials.js",
		"fetch-upwork:puppeteer": "node scripts/fetch-upwork-puppeteer.js"
	},
	"dependencies": {
		"@emotion/react": "^11.4.1",
		"@emotion/styled": "^11.3.0",
		"@hookform/resolvers": "^2.8.2",
		"@material-ui/core": "^4.12.3",
		"@material-ui/icons": "^4.11.2",
		"@mui/icons-material": "^5.0.0",
		"@mui/material": "^5.0.0",
		"@next/third-parties": "^14.2.15",
		"@reduxjs/toolkit": "^1.6.2",
		"cheerio": "^1.2.0",
		"next": "11.1.2",
		"nodemailer": "^8.0.3",
		"react": "^17.0.2",
		"react-dom": "^17.0.2",
		"react-hook-form": "^7.18.0",
		"react-redux": "^7.2.6",
		"styled-components": "^5.3.0",
		"yup": "^0.32.11"
	},
	"devDependencies": {
		"@types/material-ui": "^0.21.10",
		"@types/node": "^16.18.68",
		"@types/nodemailer": "^6.4.23",
		"@types/react": "17.0.31",
		"@types/react-dom": "^17.0.10",
		"@types/react-redux": "^7.1.20",
		"@types/styled-components": "^5.1.15",
		"babel-plugin-styled-components": "^1.13.2",
		"eslint": "^8.1.0",
		"eslint-config-next": "11.1.2",
		"postcss": "^8.3.11",
		"puppeteer": "^24.39.1",
		"typescript": "4.9.5",
		"webpack-bundle-analyzer": "^4.10.1"
	}
}
