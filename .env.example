# Google Tag Manager (optional override; default in code is GTM-PHPX26N3)
# NEXT_PUBLIC_GTM_ID=GTM-PHPX26N3

# --- Contact form: IONOS static (`next export`) ---
# Recommended on IONOS CI: force FormSubmit (never call missing /api/contact):
# NEXT_PUBLIC_CONTACT_STATIC_ONLY=1
#
# Default without API vars: FormSubmit from the browser (no Next API, no SMTP on IONOS).
# After you activate your form at https://formsubmit.co, set your form id:
# NEXT_PUBLIC_FORMSUBMIT_FORM_ID=yourFormIdOrEmail
# If unset, `companyInfo.email` from app/company-data.ts is used (first send may need email confirmation).

# Optional: use your own Node API instead of FormSubmit (full URL, no trailing slash):
# NEXT_PUBLIC_CONTACT_API_BASE_URL=https://api.example.com

# Optional: local/dev — POST to same-origin `/api/contact` (requires SMTP in .env + next dev):
# NEXT_PUBLIC_USE_NODE_CONTACT_API=1
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=hello@anchorstacktech.com
# CONTACT_MAIL_TO=hello@anchorstacktech.com
