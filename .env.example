# Contact form SMTP configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=hello@anchorstacktech.com

# Server-only: API route `/api/contact` uses this for the FormSubmit URL (not bundled to browser)
FORMSUBMIT_TOKEN=

# --- Static hosting (IONOS `next export`) — API routes are not deployed ---
# Optional: skip calling `/api/contact` and POST straight to FormSubmit (one less request)
# NEXT_PUBLIC_CONTACT_FORM_CLIENT=1
#
# Optional: FormSubmit form id after activation (recommended for production); else `companyInfo.email` is used
# NEXT_PUBLIC_FORMSUBMIT_TOKEN=
