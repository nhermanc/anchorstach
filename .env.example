# Google Tag Manager (optional override; default in code is GTM-PHPX26N3)
# NEXT_PUBLIC_GTM_ID=GTM-PHPX26N3

# Canonical site URL (sitemap / robots / metadata)
# NEXT_PUBLIC_SITE_URL=https://anchorstacktech.com

# Google Search Console verification meta tag (optional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_string

# =============================================================================
# Google reCAPTCHA v2 (contact + hire us)
# =============================================================================
# Site key: default is in next.config.js (override with NEXT_PUBLIC_RECAPTCHA_SITE_KEY if you rotate).
# Secret: set ONLY on the API host and in .env.local for dev — never commit RECAPTCHA_SECRET_KEY.
#
# Optional override — default Render URL is baked into next.config.js (anchorstacktech-contact-api.onrender.com)
# NEXT_PUBLIC_CONTACT_SUBMIT_API_URL=https://other-name.onrender.com/api/submit-inquiry
#   docs/RECAPTCHA_CONTACT_API.md
#   servers/contact-submit/README.md
#
# Optional: CONTACT_ALLOWED_ORIGINS=https://www.example.com,https://example.com (API host; preview URLs)
#
# Local: RECAPTCHA_SECRET_KEY in .env.local → POST /api/verify-recaptcha same-origin, then browser → Web3Forms.
#
# Site assistant (floating chat): local dev uses same-origin POST /api/site-chat (pages/api/site-chat.ts).
# Free: GROQ_API_KEY from https://console.groq.com/ (preferred if set). Paid: OPENAI_API_KEY instead.
# Production: set GROQ_API_KEY or OPENAI_API_KEY on Render (same service as reCAPTCHA).
# Optional: SITE_CHAT_LLM=groq|openai   GROQ_MODEL=...   OPENAI_MODEL=...
# Optional: NEXT_PUBLIC_SITE_CHAT_API_URL=https://your-service.onrender.com/api/site-chat
# Optional: NEXT_PUBLIC_SITE_CHAT_ENABLED=0   (hide the widget)

# =============================================================================
# Contact + Hire Us — pick ONE path for production static (IONOS `deploy/`)
# =============================================================================

# --- A) Fastest fix for static sites (no FormSubmit “activation” email) ---
# 1) Create a free key at https://web3forms.com (delivers to your inbox)
# 2) Add to IONOS **build** env and rebuild:
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key
# (Optional: a default key is set in code for static builds; override here to rotate.)

# --- B) Your own SMTP API (Node + contact-smtp-api) ---
# NEXT_PUBLIC_CONTACT_API_BASE_URL=https://your-contact-api.example.com
# (SMTP_* only on the Node host — see docs/IONOS_CONTACT_SMTP.md)

# --- C) FormSubmit (requires one-time activation) ---
# Open **hello@anchorstacktech.com** inbox → find FormSubmit email → click “Activate Form”.
# Or after activation, set:
# NEXT_PUBLIC_FORMSUBMIT_FORM_ID=your_form_id
# NEXT_PUBLIC_CONTACT_STATIC_ONLY=1

# Do not set NEXT_PUBLIC_CONTACT_STATIC_ONLY when using A) or B).

# --- SMTP (Node host only: contact-smtp-api OR next dev / next start) ---
SMTP_HOST=smtp.ionos.com
SMTP_PORT=587
SMTP_USER=hello@anchorstacktech.com
SMTP_PASS=your-mailbox-password
SMTP_FROM=hello@anchorstacktech.com
CONTACT_MAIL_TO=hello@anchorstacktech.com
# SMTP_SECURE=true
# CONTACT_ALLOWED_ORIGINS=https://anchorstacktech.com,https://www.anchorstacktech.com

# Local dev: Next /api/contact + SMTP
# NEXT_PUBLIC_USE_NODE_CONTACT_API=1
